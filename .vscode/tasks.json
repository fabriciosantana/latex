{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "LaTeX: Build current file",
      "type": "shell",
      "command": "mkdir -p out && latexmk -pdf -interaction=nonstopmode -synctex=1 -outdir=out ${file}",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "LaTeX: Clean current file",
      "type": "shell",
      "command": "latexmk -c -outdir=out ${file}"
    }
  ]
}
